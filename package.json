{
  "name": "material-thermostat-card",
  "version": "0.10.0",
  "description": "A Material 3 Expressive thermostat card for Home Assistant, with customizable selectors and Nest/Google Home inspired UI.",
  "type": "module",
  "main": "dist/material-thermostat-card.js",
  "module": "dist/material-thermostat-card.js",
  "license": "MIT",
  "author": "George Mihai",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "thermostat",
    "climate",
    "material-design",
    "material-you",
    "hacs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lageorgem/ha-material-thermostat-card"
  },
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "web-test-runner --config web-test-runner.config.mjs",
    "test:watch": "web-test-runner --watch --config web-test-runner.config.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^9.4.0",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/sinon": "^17.0.4",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.4.2",
    "rollup": "^4.30.1",
    "sinon": "^19.0.5",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
